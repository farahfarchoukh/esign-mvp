        <mxCell id="t_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" value="e-Sign workflow — what happens, end to end" vertex="1">
          <mxGeometry height="30" width="560" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="t_legend" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#555555;" value="Blue = Sender acts     ·     Orange = Recipient acts     ·     Green = System does it automatically" vertex="1">
          <mxGeometry height="24" width="760" x="40" y="72" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="1. Upload&#xa;&#xa;Sender uploads the PDF to be signed" vertex="1">
          <mxGeometry height="110" width="180" x="40" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="2. Prepare&#xa;&#xa;Drop signature / text / date / checkbox / radio fields and assign each recipient" vertex="1">
          <mxGeometry height="110" width="180" x="270" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="3. Send&#xa;&#xa;Each recipient is emailed a unique, private signing link" vertex="1">
          <mxGeometry height="110" width="180" x="500" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" value="4. Sign&#xa;&#xa;Recipient opens the link and fills &amp; signs in the browser (name &amp; date pre-filled)" vertex="1">
          <mxGeometry height="110" width="180" x="730" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="5. Finalize&#xa;&#xa;Signature image and all values are flattened into the PDF" vertex="1">
          <mxGeometry height="110" width="180" x="960" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="6. Complete&#xa;&#xa;When everyone has signed, the sender gets the finished, signed PDF to download" vertex="1">
          <mxGeometry height="110" width="180" x="1190" y="160" as="geometry" />
        </mxCell>
