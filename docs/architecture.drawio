<mxfile host="app.diagrams.net" type="device">
  <diagram id="esign-mvp" name="esign-mvp architecture">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- group backgrounds -->
        <mxCell id="bg_app" value="Next.js 14 App (TypeScript) — single full-stack deployment" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f0f7f0;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="30" width="450" height="410" as="geometry" />
        </mxCell>
        <mxCell id="bg_devops" value="CI / CD &amp; Containerization" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f6f0fb;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="520" width="980" height="100" as="geometry" />
        </mxCell>

        <!-- clients -->
        <mxCell id="c_sender" value="Sender (browser)&#10;Upload + Field Editor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c_recipient" value="Recipient (browser)&#10;Signing page /sign/[token]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- app internals -->
