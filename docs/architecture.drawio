<mxfile host="app.diagrams.net" type="device">
  <diagram id="esign-mvp" name="System architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- section titles -->
        <mxCell id="t_clients" value="CLIENTS" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="t_data" value="DATA &amp; EXTERNAL SERVICES" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1080" y="70" width="280" height="24" as="geometry" />
        </mxCell>

        <!-- containers -->
        <mxCell id="bg_app" value="NEXT.JS 14 APP (TypeScript) — single full-stack deployment" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5faf5;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#444444;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="720" height="520" as="geometry" />
        </mxCell>
        <mxCell id="bg_devops" value="CI / CD &amp; CONTAINERIZATION" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f9f5fc;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#444444;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="1320" height="130" as="geometry" />
        </mxCell>

        <!-- clients -->
        <mxCell id="c_sender" value="Sender&#10;(browser)&#10;&#10;Upload + Field editor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="c_recipient" value="Recipient&#10;(browser)&#10;&#10;Signing page /sign/[token]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="200" height="95" as="geometry" />
        </mxCell>

        <!-- app internals -->
        <mxCell id="fe" value="Frontend (React)&#10;&#10;react-pdf · signature canvas · drag-drop fields" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="150" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sw" value="Swagger UI&#10;/api-docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="290" width="230" height="70" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API Routes&#10;(backend)&#10;&#10;/api/documents&#10;/api/sign&#10;/api/openapi&#10;&#10;Per-recipient&#10;signing tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="620" y="150" width="180" height="440" as="geometry" />
        </mxCell>
        <mxCell id="stamp" value="pdf-lib&#10;stamp &amp; flatten" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="850" y="170" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="mail" value="Nodemailer&#10;email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="850" y="320" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="prisma" value="Prisma ORM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="850" y="470" width="150" height="80" as="geometry" />
        </mxCell>

        <!-- data + external services -->
        <mxCell id="files" value="File storage (local)&#10;uploads: original + signed PDFs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="150" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="smtp" value="SMTP (Gmail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="300" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inbox" value="Recipient inbox&#10;(signing link)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="390" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="db" value="SQLite (via Prisma)&#10;Document · Recipient · Field" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1090" y="480" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- devops -->
        <mxCell id="gh" value="GitHub repo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="90" y="775" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ci" value="Actions CI&#10;tsc · next build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="775" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="cd" value="Actions CD&#10;build + push image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="775" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ghcr" value="GHCR&#10;Docker image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="910" y="775" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="docker" value="Docker / compose&#10;(one-command run)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="775" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- edges: client <-> app -->
        <mxCell id="e_s1" value="1 upload · 2 place fields" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c_sender" target="fe"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_r1" value="4 open signing link" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.25;entryX=0;entryY=1;" edge="1" parent="1" source="c_recipient" target="fe"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- edges: app internal -->
        <mxCell id="e_fe_api" value="HTTP (fetch)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.1;" edge="1" parent="1" source="fe" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sw_api" value="reads /api/openapi" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.4;endArrow=open;" edge="1" parent="1" source="sw" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_stamp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.1;entryX=0;entryY=0.5;" edge="1" parent="1" source="api" target="stamp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_mail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.4;entryX=0;entryY=0.5;" edge="1" parent="1" source="api" target="mail"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_prisma" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.8;entryX=0;entryY=0.5;" edge="1" parent="1" source="api" target="prisma"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- edges: app -> data/services -->
        <mxCell id="e_api_files" value="PDF read / write" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=0;" edge="1" parent="1" source="api" target="files">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="128" />
              <mxPoint x="1200" y="128" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_mail_smtp" value="3 invite · 6 completed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="mail" target="smtp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_smtp_inbox" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="smtp" target="inbox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_prisma_db" value="DB read / write" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.4;" edge="1" parent="1" source="prisma" target="db"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- edge: email delivers signing link back to recipient -->
        <mxCell id="e_inbox_rec" value="emails signing link" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="inbox" target="c_recipient">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1200" y="680" />
              <mxPoint x="140" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- edges: devops -->
        <mxCell id="e_gh_ci" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="gh" target="ci"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ci_cd" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ci" target="cd"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cd_ghcr" value="publish" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="cd" target="ghcr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ghcr_docker" value="pull / run" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ghcr" target="docker"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="signing-pipeline" name="Signing pipeline (business flow)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t_title" value="e-Sign workflow — what happens, end to end" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_legend" value="Blue = Sender acts     ·     Orange = Recipient acts     ·     Green = System does it automatically" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="760" height="24" as="geometry" />
        </mxCell>

        <mxCell id="p1" value="1. Upload&#10;&#10;Sender uploads the PDF to be signed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="2. Prepare&#10;&#10;Drop signature / text / date / checkbox / radio fields and assign each recipient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="270" y="160" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="3. Send&#10;&#10;Each recipient is emailed a unique, private signing link" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="500" y="160" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="4. Sign&#10;&#10;Recipient opens the link and fills &amp; signs in the browser (name &amp; date pre-filled)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="730" y="160" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="5. Finalize&#10;&#10;Signature image and all values are flattened into the PDF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="960" y="160" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="6. Complete&#10;&#10;When everyone has signed, the sender gets the finished, signed PDF to download" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1190" y="160" width="180" height="110" as="geometry" />
        </mxCell>

        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="p5" target="p6"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
