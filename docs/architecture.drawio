  <diagram name="Signing pipeline (business flow)" id="eDhqiF5MXCrFMhk-ODbK">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
