# Prisma SQLite database location
DATABASE_URL="file:./dev.db"

# Public URL the app is served at (used to build signing/download links in emails)
APP_URL="http://localhost:3000"

# --- SMTP / email (OPTIONAL) ---
# If you leave ALL of the SMTP_* vars unset, the app automatically creates a
# Nodemailer "Ethereal" test account at runtime and prints a preview URL to the
# server console for every email it sends. That means the full flow works in a
# demo WITHOUT any real credentials.
#
# To send real email, fill these in. Example values shown are for SendGrid:
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="<your SendGrid API key>"
# MAIL_FROM="you@your-verified-domain.com"
